{
  "name": "charpente-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo charpente : moteur paramétrique (@charpente/moteur) + configurateur web (@charpente/web).",
  "scripts": {
    "test": "pnpm -r --if-present test",
    "type-check": "pnpm -r --if-present type-check",
    "demo": "pnpm --filter @charpente/moteur demo",
    "export": "pnpm --filter @charpente/moteur export",
    "dev": "pnpm --filter @charpente/web dev",
    "build:web": "pnpm --filter @charpente/web build"
  }
}
